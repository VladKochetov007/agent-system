# ============================================================
# Multi-venue connector credentials
# Copy this file to .env and fill in your actual keys
# ============================================================

# Binance Spot
BINANCE_SPOT_API_KEY=***
BINANCE_SPOT_API_SECRET=***

BINANCE_SPOT_ED25519=***
BINANCE_SPOT_ED25519_SECRET=***

# Binance Futures (USDT-margined perpetuals)
BINANCE_LINEAR_API_KEY=***
BINANCE_LINEAR_API_SECRET=***

# Bybit Perpetuals 
# only 87.121.50.19
BYBIT_PERP_API_KEY=***
BYBIT_PERP_API_SECRET=***

KRAKEN_FUTURES_API_KEY=***
KRAKEN_FUTURES_API_SECRET=***

# dYdX v4 (wallet address required for data access)
DYDX_PERP_WALLET_ADDRESS=***
DYDX_PRIVATE_KEY=***

# OKX Swap
# only 87.121.50.19
OKX_API_KEY=***
OKX_API_SECRET=***
OKX_API_PASSPHRASE=***

# Hyperliquid (currently disabled in config)
HYPERLIQUID_PERP_WALLET_ADDRESS=***
HYPERLIQUID_PRIVATE=***

